# Для локальной разработки (npm run dev)
VITE_API_URL=http://localhost:8080

# Для Docker (docker-compose) — заполнить в .env
POSTGRES_DB=psportal
POSTGRES_USER=psportal
POSTGRES_PASSWORD=замени_на_пароль

JWT_SECRET=замени_на_случайную_строку_мин_32_символа

# Ключ шифрования переписки в чате (AES, хранится в БД зашифрованной)
MESSAGE_ENCRYPTION_KEY=замени_на_случайную_строку_любой_длины

FRONTEND_URL=https://твой-домен.ru

# Timeweb S3 — хранение файлов (аватары, материалы, вложения)
# Пока бакет не создан — оставь S3_ENABLED=false, файлы будут писаться на локальный диск
S3_ENABLED=false
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Необязательно: свой публичный домен/CDN перед бакетом. Если пусто — используется ENDPOINT/BUCKET
S3_PUBLIC_URL=

# TURN-сервер для видеоконференций (нужен на проде: без него медиа не проходит строгий NAT)
# TURN_URL указывает на IP самого VDS (не на балансировщик!), порт 3478
# Открой в файрволе: 3478/tcp+udp и 49160-49200/udp. Запуск: docker compose --profile turn up -d coturn
TURN_URL=turn:IP_твоего_VDS:3478
TURN_USER=psportal
TURN_PASSWORD=замени_на_пароль

# Dozzle — просмотр логов контейнеров (порт 8888)
DOZZLE_USER=admin
DOZZLE_PASSWORD=замени_на_пароль
